#include <stdio.h>

int main() {
    int arr[9];
    int i;

    // Input elements
    for(i = 0; i < 9; i++) {
        printf("Enter value of index %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    // Display original array
    printf("\nOriginal Array: ");
    for(i = 0; i < 9; i++) {
        printf("%d ", arr[i]);
    }

    // Display even numbers
    printf("\nEven Numbers: ");
    for(i = 0; i < 9; i++) {
        if(arr[i] % 2 == 0) {
            printf("%d ", arr[i]);
        }
    }

    // Display odd numbers
    printf("\nOdd Numbers: ");
    for(i = 0; i < 9; i++) {
        if(arr[i] % 2 != 0) {
            printf("%d ", arr[i]);
        }
    }

    return 0;
}
